# Database
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"

# Postgres credentials consumed by docker-compose.yml. POSTGRES_PASSWORD is
# required (compose fails to start without it); the others have defaults.
# If the password contains reserved URI characters (e.g. @ : / ? # % & + space),
# set POSTGRES_PASSWORD_ENCODED to its percent-encoded form so DATABASE_URL stays
# valid; it defaults to POSTGRES_PASSWORD when unset.
POSTGRES_DB=readstr
POSTGRES_USER=nostr_user
POSTGRES_PASSWORD=
POSTGRES_PASSWORD_ENCODED=

# Nostr
NOSTR_PRIVATE_KEY=
DEFAULT_RELAYS="wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band"

# Optional: overrides the admin npub. Defaults to the bundled admin npub when unset.
NEXT_PUBLIC_ADMIN_NPUB=

# Flash subscription webhook signing key (JWT HS256 verification).
FLASH_SUBSCRIPTION_KEY=

# Temporary fallback escape hatch for the Flash webhook. When "true", if the
# verified JWT carries no user_public_key the verifier falls back to the
# unsigned request body identity. This weakens the signed-identity binding that
# protects against webhook replay/retarget attacks. Keep unset; only enable
# briefly while confirming Flash's token schema, then remove.
ALLOW_FLASH_BODY_IDENTITY=

# Square Payment (for subscription)
NEXT_PUBLIC_SQUARE_PAYMENT_LINK="https://square.link/u/YOUR_LINK_HERE"
SQUARE_WEBHOOK_SECRET="your_webhook_secret"
CRON_SECRET="random_secret_for_cron_jobs"