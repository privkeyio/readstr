# Production Environment Variables for Readstr
# Copy this file to .env.production and fill in the values

# Database Configuration
DATABASE_URL="postgresql://nostr_user:nostr_password@postgres:5432/nostr_feedz"

# Application Environment
NODE_ENV="production"

# Nostr Configuration
DEFAULT_RELAYS="wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band,wss://relay.snort.social"
NOSTR_BUNKER_URL=""

# Optional: overrides the admin npub. Defaults to the bundled admin npub when unset.
NEXT_PUBLIC_ADMIN_NPUB=""

# PayWithFlash Configuration
NEXT_PUBLIC_FLASH_CHECKOUT_URL=""  # Your Flash subscription checkout URL
FLASH_SUBSCRIPTION_KEY=""  # Your Flash subscription key for JWT verification

# Temporary fallback escape hatch for the Flash webhook — MUST remain unset in
# production. When "true", if the verified JWT carries no user_public_key the
# verifier falls back to the unsigned request body identity, weakening the
# signed-identity binding that prevents webhook replay/retarget attacks. Only
# enable briefly while confirming Flash's token schema, then remove.
ALLOW_FLASH_BODY_IDENTITY=""

# Security
NEXTAUTH_SECRET=""  # Generate with: openssl rand -base64 32

# Optional: Analytics and Monitoring
NEXT_PUBLIC_ANALYTICS_ID=""

# Optional: Error Tracking
SENTRY_DSN=""

# Next.js Configuration
NEXT_TELEMETRY_DISABLED=1