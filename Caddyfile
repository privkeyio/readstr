{
    email kyle@privkey.io
}

readstr.privkey.io {
    # Reverse proxy to the Next.js app
    reverse_proxy app:3000 {
        # Overwrite X-Forwarded-For at the trust boundary so clients cannot
        # inject spoofed entries; the app reads the rightmost (real peer) hop.
        header_up X-Forwarded-For {remote_host}

        # Health check
        health_uri /api/health
        health_interval 30s
        health_timeout 5s
    }

    # Enable compression
    encode gzip

    # Security headers (CSP/HSTS/nosniff/Referrer-Policy) are emitted by the app
    # in next.config.mjs as the single authoritative source — do not duplicate
    # them here, as browsers intersect multiple CSPs.
    header {
        # Remove server information
        -Server
    }

    # Log to stdout
    log {
        output stdout
        format console
    }
}
